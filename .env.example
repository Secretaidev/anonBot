# Local MongoDB (no Atlas needed — install MongoDB Community first)
MONGODB_URL=mongodb://127.0.0.1:27017/anoybot

# Atlas (uncomment when Network Access allows your IP / 0.0.0.0/0)
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/anoybot?retryWrites=true&w=majority

BOT_TOKEN=your_bot_token
LOG_CHANNEL_ID=-1001234567890
ADMIN_IDS=123456789
MONGODB_DB_NAME=anoybot
TELEGRAM_API_BASE_URL=
TELEGRAM_API_FILE_URL=
MATCH_TIMEOUT_SECONDS=300
MATCH_WIDEN_SECONDS=90
SEARCH_PULSE_SECONDS=25
STATS_CACHE_SECONDS=30
USER_CACHE_SECONDS=8
MAX_MESSAGE_LENGTH=4096
RATE_LIMIT_PER_MINUTE=25
BRAND_NAME=AnoyBot
AUTO_BAN_REPORTS=3
LOG_CHAT_MESSAGES=true
BROADCAST_CONCURRENCY=20
FLOOD_NOTIFY_COOLDOWN=30
MESSAGE_LOG_BATCH_SIZE=40
MESSAGE_LOG_FLUSH_SECONDS=8
TYPING_COOLDOWN_SECONDS=4
UPSERT_COOLDOWN_SECONDS=45
